# قاعدة البيانات MongoDB
# استخدم Atlas: https://www.mongodb.com/cloud/atlas
MONGODB_URI=mongodb+srv://username:password@cluster0.xxxxx.mongodb.net/databasename?appName=Cluster0

# إعدادات JWT
JWT_SECRET=your-secure-jwt-secret-key-here

# مفاتيح الـ API
GEMINI_API_KEY=your-gemini-api-key-here
# GROQ_API_KEY=your-groq-api-key-here

# إعدادات السيرفر
PORT=3001
NODE_ENV=production

# رابط الواجهة الأمامية (مهم للـ CORS)
CLIENT_URL=https://your-frontend-domain.onrender.com
# FRONTEND_URL اختياري إذا كان لديك أكثر من دومين أو دومين مخصص
# FRONTEND_URL=https://your-custom-domain.com

# متغير Vite للواجهة الأمامية
# إذا كان نفس تطبيق Render يخدم الواجهة والـ API معاً، اتركه فارغاً ليستخدم same-origin تلقائياً.
# وإذا كان الباك اند في خدمة مستقلة، ضع رابط خدمة الـ API هنا.
VITE_API_URL=
